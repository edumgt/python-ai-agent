PORT=8000
BASE_URL=http://localhost:8000

# WSL agent -> Windows host Ollama
# Update this IP if the Windows host gateway changes.
OLLAMA_BASE_URL=http://172.29.32.1:11434
LLM_MODEL=llama3:latest
EMBED_MODEL=nomic-embed-text

# Local SQLite metadata DB in WSL
SQLITE_PATH=./data/app.db
SESSION_SECRET=dev-secret

# MongoDB (Docker: fin_user/fin_pass)
MONGO_URI=mongodb://fin_user:fin_pass@localhost:27017/fin_ai?authSource=admin
MONGO_DB=fin_ai

# Redis (Docker)
REDIS_URL=redis://localhost:6379

RAW_DIR=./data/raw
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
TOP_K=6
MAX_CONTEXT_CHUNKS=10
DOC_VERSION_STRATEGY=latest

# Docker Qdrant exposed to WSL host
VECTOR_STORE=qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=law_chunks

ADMIN_EMAILS=
TRUST_PROXY=0
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
OLLAMA_TIMEOUT_MS=300000

# 알림 채널 (개발 환경 – 필요한 채널만 설정)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
KAKAO_SENDER_KEY=
KAKAO_PHONE=
SMS_FROM=
SMS_TO=
