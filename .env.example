# Server
PORT=8000
BASE_URL=http://localhost:8000

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=llama3.1
EMBED_MODEL=nomic-embed-text

# SQLite
SQLITE_PATH=./data/app.db

# Session
SESSION_SECRET=change-me-super-secret

# RAG
RAW_DIR=./data/raw
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
TOP_K=6
MAX_CONTEXT_CHUNKS=10

# Doc version strategy: latest | all
DOC_VERSION_STRATEGY=latest

# ─────────────────────────────────────
# Vector Store backend: sqlite | qdrant
# ─────────────────────────────────────
# Use "sqlite" (default) for local development / small datasets.
# Use "qdrant" for production / large datasets (requires Qdrant service).
VECTOR_STORE=sqlite

# Qdrant connection (only used when VECTOR_STORE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=law_chunks

# Comma-separated emails that become admin on register
ADMIN_EMAILS=

# Reverse proxy / cookie options
TRUST_PROXY=0
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Ollama timeouts (ms). Increase if you hit 120000ms timeouts.
OLLAMA_TIMEOUT_MS=300000
# Optional overrides
# OLLAMA_CHAT_TIMEOUT_MS=300000
# OLLAMA_EMBED_TIMEOUT_MS=120000

# -----------------------------
# Collector (law.go / public API)
# -----------------------------
# Set your API key / OC code (issued by the provider)
LAWGO_API_KEY=
# Optional: base url & endpoints (adjust to your issued API spec)
LAWGO_BASE_URL=https://open.law.go.kr/LSO/openapi/
LAWGO_LAW_LIST_ENDPOINT=law/list
LAWGO_LAW_DETAIL_ENDPOINT=law/detail
LAWGO_CASE_LIST_ENDPOINT=case/list
LAWGO_CASE_DETAIL_ENDPOINT=case/detail
LAWGO_TIMEOUT_MS=300000

# -----------------------------
# Ollama client timeout (ms)
# -----------------------------
OLLAMA_TIMEOUT_MS=300000
