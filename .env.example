# ─────────────────────────────────────────────────────────────────────────────
# 금융 AI Agent – 환경변수 예시 (.env.example)
# 복사: cp .env.example .env  또는  cp .env.example .env.dev
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8000

# Ollama (local LLM + embeddings + VLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=llama3.1
EMBED_MODEL=nomic-embed-text
VLM_MODEL=llava          # 이미지/슬라이드 설명용 비전 모델 (ollama pull llava)

# MongoDB (사용자 인증)
MONGO_URI=mongodb://fin_user:fin_pass@localhost:27017/fin_ai?authSource=admin

# Redis (세션)
REDIS_URL=redis://localhost:6379
SESSION_TTL=86400

# SQLite (CB 통계, 금융상품, 채팅, 포트폴리오, 주문)
SQLITE_PATH=./data/app.db

# 금융 CSV 데이터 경로 (디렉토리)
DATA_DIR=./data

# Qdrant (벡터 DB)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=fin_chunks

# RAG 설정
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
TOP_K=6

# 관리자 이메일 (쉼표 구분)
ADMIN_EMAILS=

# GitHub API (크롤링용 – rate limit 증가)
GITHUB_TOKEN=

# 쿠키 보안
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ─────────────────────────────────────────────────────────────────────────────
# 증권사 Open API (설정 후 UI에서도 변경 가능)
# ─────────────────────────────────────────────────────────────────────────────

# 한국투자증권 (KIS) Open API
# 신청: https://apiportal.koreainvestment.com/
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# true=모의투자, false=실전투자
KIS_PAPER=true

# LS증권 eBest Open API
# 신청: https://openapi.ebestsec.co.kr/
EBEST_APP_KEY=
EBEST_APP_SECRET=
EBEST_ACCOUNT_NO=
