# ─────────────────────────────────────────────────────────────────────────────
# 금융 AI Agent – 환경변수 예시 (.env.example)
# 복사: cp .env.example .env  또는  cp .env.example .env.dev
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8000

# ── Supabase (선택 – PostgreSQL 기반 관계형 CRUD) ─────────────────────────────
# Supabase Dashboard → Project Settings → API 에서 확인
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=      # service_role 키 (서버 사이드 전용, 절대 노출 금지)

# ── JWT 인증 (API 클라이언트 / 모바일용) ──────────────────────────────────────
# 최소 32자 이상의 무작위 문자열 권장: openssl rand -hex 32
JWT_SECRET=change-me-jwt-secret-32chars-min!!
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL=900        # 액세스 토큰 유효 시간 (초, 기본 15분)
JWT_REFRESH_TTL=604800    # 리프레시 토큰 유효 시간 (초, 기본 7일)

# Ollama (local LLM + embeddings + VLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=llama3.1
EMBED_MODEL=nomic-embed-text
VLM_MODEL=llava          # 이미지/슬라이드 설명용 비전 모델 (ollama pull llava)

# MongoDB (사용자 인증)
MONGO_URI=mongodb://fin_user:fin_pass@localhost:27017/fin_ai?authSource=admin

# Redis (세션)
REDIS_URL=redis://localhost:6379
SESSION_TTL=86400

# SQLite (CB 통계, 금융상품, 채팅, 포트폴리오, 주문)
SQLITE_PATH=./data/app.db

# 금융 CSV 데이터 경로 (디렉토리)
DATA_DIR=./data

# Qdrant (벡터 DB)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=fin_chunks

# RAG 설정
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
TOP_K=6

# 관리자 이메일 (쉼표 구분)
ADMIN_EMAILS=

# GitHub API (크롤링용 – rate limit 증가)
GITHUB_TOKEN=

# 쿠키 보안
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ─────────────────────────────────────────────────────────────────────────────
# 증권사 Open API (설정 후 UI에서도 변경 가능)
# ─────────────────────────────────────────────────────────────────────────────

# 한국투자증권 (KIS) Open API
# 신청: https://apiportal.koreainvestment.com/
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# true=모의투자, false=실전투자
KIS_PAPER=true

# LS증권 eBest Open API
# 신청: https://openapi.ebestsec.co.kr/
EBEST_APP_KEY=
EBEST_APP_SECRET=
EBEST_ACCOUNT_NO=

# ─────────────────────────────────────────────────────────────────────────────
# 알림 채널 설정 (선택 – 필요한 채널만 설정하세요)
# 설정된 채널로 매매 성공/실패 알림이 자동 발송됩니다.
# UI의 [알림 설정] 탭에서 사용자별로도 변경할 수 있습니다.
# ─────────────────────────────────────────────────────────────────────────────

# 텔레그램 (선택)
# 1. BotFather 에서 봇 생성 후 토큰 발급: /newbot
# 2. 채팅 ID 확인: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack Incoming Webhook (선택)
# 1. https://api.slack.com/apps → 앱 생성 → Incoming Webhooks 활성화
# 2. 채널 추가 후 Webhook URL 복사
SLACK_WEBHOOK_URL=

# 이메일 알림 (선택, SMTP / STARTTLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# 카카오 알림톡 (선택, CoolSMS API)
# 신청: https://coolsms.co.kr/
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
KAKAO_SENDER_KEY=   # 카카오 채널 발신 프로필 키
KAKAO_PHONE=        # 수신 전화번호 (예: 01012345678)

# SMS 문자 알림 (선택, CoolSMS API – COOLSMS_API_KEY/SECRET 공용)
SMS_FROM=           # 발신 번호 (CoolSMS 등록 번호)
SMS_TO=             # 수신 번호
